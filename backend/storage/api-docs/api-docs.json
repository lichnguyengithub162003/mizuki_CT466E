        "/api/v1/customer/favorites/{product_id}": {
            "delete": {
                "tags": [
                    "Customer Favorites"
                ],
                "summary": "Bỏ sản phẩm khỏi yêu thích",
                "operationId": "deleteCustomerFavorite",
                "parameters": [
                    {
                        "name": "product_id",
                        "in": "path",
