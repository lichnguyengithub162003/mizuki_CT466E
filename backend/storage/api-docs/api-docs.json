{
    "openapi": "3.0.0",
    "info": {
        "title": "Mizuki API",
        "description": "API cho hệ thống thương mại mỹ phẩm và đặt lịch clinic Mizuki",
        "version": "1.0.0"
    },
    "paths": {
        "/api/v1/brands": {
            "get": {
                "tags": [
                    "Catalog"
                ],
                "summary": "Danh sách thương hiệu đang hiển thị",
                "operationId": "listBrands",
                "responses": {
                    "200": {
                        "description": "Danh sách thương hiệu",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Lấy danh sách thương hiệu thành công!"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/brands/{slug}": {
            "get": {
                "tags": [
                    "Catalog"
                ],
                "summary": "Chi tiết gian hàng thương hiệu",
                "operationId": "showBrand",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "description": "Slug của thương hiệu",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "mizuki"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Chi tiết thương hiệu",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "object"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Lấy thông tin thương hiệu thành công!"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Không tìm thấy thương hiệu"
                    }
                }
            }
        },
        "/api/v1/categories": {
            "get": {
                "tags": [
                    "Catalog"
                ],
                "summary": "Danh sách danh mục đang hiển thị theo cấu trúc phân cấp",
                "operationId": "listCategories",
                "responses": {
                    "200": {
                        "description": "Danh sách danh mục",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Lấy danh sách danh mục thành công!"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/products": {
            "get": {
                "tags": [
                    "Catalog"
                ],
                "summary": "Danh sách sản phẩm đang hiển thị",
                "operationId": "listProducts",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 20,
                            "maximum": 100
                        }
                    },
                    {
                        "name": "category_id",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "brand_id",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "price_min",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 0
                        }
                    },
                    {
                        "name": "price_max",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 0
                        }
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "default": "newest",
                            "enum": [
                                "newest",
                                "best_selling",
                                "price_asc",
                                "price_desc"
                            ]
                        }
                    },
                    {
                        "name": "keyword",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Danh sách sản phẩm có phân trang",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Lấy danh sách sản phẩm thành công!"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Query params không hợp lệ"
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Catalog",
            "description": "Catalog"
        }
    ]
}