{
    "openapi": "3.0.0",
    "info": {
        "title": "Mizuki API",
        "description": "API cho hệ thống thương mại mỹ phẩm và đặt lịch clinic Mizuki",
        "version": "1.0.0"
    },
    "paths": {
        "/api/v1/admin/promotions": {
            "get": {
                "tags": [
                    "Admin Promotions"
                ],
                "summary": "Danh sách promotion theo quyền quản trị",
                "operationId": "adminListPromotions",
                "parameters": [
                    {
                        "name": "is_active",
                        "in": "query",
                        "schema": {
                            "type": "boolean"
                        }
                    },
                    {
                        "name": "discount_type",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "percentage",
                                "fixed_amount"
                            ]
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "maximum": 100,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Danh sách promotion"
                    },
                    "401": {
                        "description": "Chưa đăng nhập"
                    },
                    "403": {
                        "description": "Không có quyền quản trị promotion"
                    }
                }
            },
            "post": {
                "tags": [
                    "Admin Promotions"
                ],
                "summary": "Tạo promotion",
                "operationId": "adminCreatePromotion",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Đã tạo promotion"
                    },
                    "403": {
                        "description": "Không có quyền tạo promotion"
                    },
                    "422": {
                        "description": "Dữ liệu không hợp lệ"
                    }
                }
            }
        },
        "/api/v1/admin/promotions/{id}": {
            "delete": {
                "tags": [
                    "Admin Promotions"
                ],
                "summary": "Xóa promotion",
                "operationId": "adminDeletePromotion",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Đã xóa promotion"
                    },
                    "403": {
                        "description": "Không có quyền xóa promotion"
                    },
                    "404": {
                        "description": "Không tìm thấy promotion"
                    }
                }
            },
            "patch": {
                "tags": [
                    "Admin Promotions"
                ],
                "summary": "Cập nhật promotion",
                "operationId": "adminUpdatePromotion",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Đã cập nhật promotion"
                    },
                    "403": {
                        "description": "Không có quyền sửa promotion"
                    },
                    "404": {
                        "description": "Không tìm thấy promotion"
                    }
                }
            }
        },
        "/api/v1/admin/promotions/{id}/usage-stats": {
            "get": {
                "tags": [
                    "Admin Promotions"
                ],
                "summary": "Thống kê lượt sử dụng promotion",
                "operationId": "adminPromotionUsageStats",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Thống kê lượt sử dụng"
                    },
                    "403": {
                        "description": "Không có quyền xem promotion"
                    },
                    "404": {
                        "description": "Không tìm thấy promotion"
                    }
                }
            }
        },
        "/api/v1/brands": {
            "get": {
                "tags": [
                    "Catalog"
                ],
                "summary": "Danh sách thương hiệu đang hiển thị",
                "operationId": "listBrands",
                "responses": {
                    "200": {
                        "description": "Danh sách thương hiệu",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Lấy danh sách thương hiệu thành công!"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/brands/{slug}": {
            "get": {
                "tags": [
                    "Catalog"
                ],
                "summary": "Chi tiết gian hàng thương hiệu",
                "operationId": "showBrand",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "description": "Slug của thương hiệu",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "mizuki"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Chi tiết thương hiệu",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "object"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Lấy thông tin thương hiệu thành công!"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Không tìm thấy thương hiệu"
                    }
                }
            }
        },
        "/api/v1/categories": {
            "get": {
                "tags": [
                    "Catalog"
                ],
                "summary": "Danh sách danh mục đang hiển thị theo cấu trúc phân cấp",
                "operationId": "listCategories",
                "responses": {
                    "200": {
                        "description": "Danh sách danh mục",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Lấy danh sách danh mục thành công!"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/products": {
            "get": {
                "tags": [
                    "Catalog"
                ],
                "summary": "Danh sách sản phẩm đang hiển thị",
                "operationId": "listProducts",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 20,
                            "maximum": 100
                        }
                    },
                    {
                        "name": "category_id",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "brand_id",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "price_min",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 0
                        }
                    },
                    {
                        "name": "price_max",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 0
                        }
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "default": "newest",
                            "enum": [
                                "newest",
                                "best_selling",
                                "price_asc",
                                "price_desc"
                            ]
                        }
                    },
                    {
                        "name": "keyword",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Danh sách sản phẩm có phân trang",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Lấy danh sách sản phẩm thành công!"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Query params không hợp lệ"
                    }
                }
            }
        },
        "/api/v1/products/search": {
            "get": {
                "tags": [
                    "Catalog"
                ],
                "summary": "Gợi ý sản phẩm theo từ khóa",
                "operationId": "searchProductSuggestions",
                "parameters": [
                    {
                        "name": "keyword",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "serum",
                            "minLength": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 8,
                            "maximum": 20,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Danh sách gợi ý sản phẩm",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Tìm kiếm thành công!"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Query params không hợp lệ"
                    }
                }
            }
        },
        "/api/v1/products/{slug}": {
            "get": {
                "tags": [
                    "Catalog"
                ],
                "summary": "Chi tiết sản phẩm",
                "operationId": "showProduct",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "description": "Slug của sản phẩm",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "serum-phuc-hoi-da"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Chi tiết sản phẩm, biến thể và tồn kho",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "object"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Lấy chi tiết sản phẩm thành công!"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Không tìm thấy sản phẩm"
                    }
                }
            }
        },
        "/api/v1/customer/cart": {
            "get": {
                "tags": [
                    "Customer Cart"
                ],
                "summary": "Xem giỏ hàng hiện tại",
                "operationId": "showCustomerCart",
                "responses": {
                    "200": {
                        "description": "Chi tiết giỏ hàng"
                    },
                    "401": {
                        "description": "Chưa đăng nhập"
                    },
                    "403": {
                        "description": "Không phải tài khoản khách hàng"
                    }
                }
            }
        },
        "/api/v1/customer/cart/items": {
            "post": {
                "tags": [
                    "Customer Cart"
                ],
                "summary": "Thêm biến thể sản phẩm vào giỏ hàng",
                "operationId": "addCustomerCartItem",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "product_variant_id",
                                    "quantity"
                                ],
                                "properties": {
                                    "product_variant_id": {
                                        "type": "integer"
                                    },
                                    "quantity": {
                                        "type": "integer",
                                        "minimum": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Đã thêm vào giỏ hàng"
                    },
                    "401": {
                        "description": "Chưa đăng nhập"
                    },
                    "422": {
                        "description": "Dữ liệu hoặc tồn kho không hợp lệ"
                    }
                }
            }
        },
        "/api/v1/customer/cart/items/{id}": {
            "delete": {
                "tags": [
                    "Customer Cart"
                ],
                "summary": "Xóa sản phẩm khỏi giỏ hàng",
                "operationId": "deleteCustomerCartItem",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Đã xóa sản phẩm khỏi giỏ hàng"
                    },
                    "404": {
                        "description": "Không tìm thấy sản phẩm trong giỏ"
                    }
                }
            },
            "patch": {
                "tags": [
                    "Customer Cart"
                ],
                "summary": "Cập nhật số lượng sản phẩm trong giỏ",
                "operationId": "updateCustomerCartItem",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "quantity"
                                ],
                                "properties": {
                                    "quantity": {
                                        "type": "integer",
                                        "minimum": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Đã cập nhật giỏ hàng"
                    },
                    "404": {
                        "description": "Không tìm thấy sản phẩm trong giỏ"
                    },
                    "422": {
                        "description": "Số lượng vượt tồn kho"
                    }
                }
            }
        },
        "/api/v1/customer/cart/branch": {
            "patch": {
                "tags": [
                    "Customer Cart"
                ],
                "summary": "Chọn chi nhánh cho giỏ hàng",
                "operationId": "selectCustomerCartBranch",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "branch_id"
                                ],
                                "properties": {
                                    "branch_id": {
                                        "type": "integer"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Đã chọn chi nhánh"
                    },
                    "422": {
                        "description": "Chi nhánh không hợp lệ"
                    }
                }
            }
        },
        "/api/v1/customer/cart/promotions": {
            "get": {
                "tags": [
                    "Customer Cart"
                ],
                "summary": "Xem voucher khả dụng cho giỏ hàng",
                "operationId": "listAvailableCartPromotions",
                "responses": {
                    "200": {
                        "description": "Danh sách voucher khả dụng"
                    },
                    "401": {
                        "description": "Chưa đăng nhập"
                    },
                    "403": {
                        "description": "Không phải tài khoản khách hàng"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/customer/cart/promotion": {
            "post": {
                "tags": [
                    "Customer Cart"
                ],
                "summary": "Áp dụng voucher cho giỏ hàng",
                "operationId": "applyCartPromotion",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "code"
                                ],
                                "properties": {
                                    "code": {
                                        "type": "string",
                                        "example": "MIZUKI10"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Đã áp dụng voucher"
                    },
                    "401": {
