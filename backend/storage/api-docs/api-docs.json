                    },
                    "422": {
                        "description": "Voucher không đủ điều kiện áp dụng"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Customer Cart"
                ],
                "summary": "Hủy voucher đã áp dụng trên giỏ hàng",
                "operationId": "removeCartPromotion",
                "responses": {
                    "200": {
                        "description": "Đã hủy voucher"
                    },
                    "401": {
                        "description": "Chưa đăng nhập"
                    },
                    "404": {
                        "description": "Giỏ hàng chưa áp dụng voucher"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
