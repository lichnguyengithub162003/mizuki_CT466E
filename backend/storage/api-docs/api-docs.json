                    "401": {
                        "description": "Chưa đăng nhập"
                    }
                }
            },
            "post": {
                "tags": [
                    "Customer Favorites"
                ],
                "summary": "Thêm sản phẩm vào yêu thích",
                "operationId": "storeCustomerFavorite",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "product_id"
